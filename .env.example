# .env.example — copy to .env and fill in your values
# NEVER commit .env to git

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Database URL (Railway MySQL)
DATABASE_URL=mysql+pymysql://root:PASSWORD@roundhouse.proxy.rlwy.net:38486/railway

# Flask settings
FLASK_ENV=production
FLASK_DEBUG=false

# Optional: set this to enable WhiteNoise static file serving
USE_WHITENOISE=true
